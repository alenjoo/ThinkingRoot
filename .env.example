# ThinkingRoot — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored. Never commit real API keys.

# ── LLM Providers ─────────────────────────────────────────────────────────────
# Set whichever provider you use. The active provider is configured in
# .thinkingroot/config.toml under [llm] default_provider.

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Groq (free tier available)
GROQ_API_KEY=gsk_...

# DeepSeek
DEEPSEEK_API_KEY=...

# AWS Bedrock — uses ~/.aws/credentials by default.
# Set these only if you need to override the default profile.
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=us-east-1

# Ollama — no key needed. Just set the base URL if non-default.
# OLLAMA_BASE_URL=http://localhost:11434

# ── ThinkingRoot Server ────────────────────────────────────────────────────────
# Optional API key for the REST server (set --api-key or this env var)
# THINKINGROOT_API_KEY=your-secret-key
